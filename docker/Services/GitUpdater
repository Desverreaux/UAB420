FROM python:3.11-slim
WORKDIR /app
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*
COPY docker/Services/GitUpdater.requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt
COPY backend/gitWebhook.py .
EXPOSE 8500
CMD ["uvicorn", "gitWebhook:gitApp", "--host", "0.0.0.0", "--port", "8500"]